generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                             Int      @id @default(autoincrement())
  dni                            String   @unique
  roleId                         Int
  createdAt                      DateTime @default(now())
  email                          String?  @unique
  license                        String?
  password                       String?
  updatedAt                      DateTime @updatedAt
  profile                        Profile?
  Study_Study_biochemistIdToUser Study[]  @relation("Study_biochemistIdToUser")
  studies                        Study[]
  role                           Role     @relation(fields: [roleId], references: [id])
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model Profile {
  id        Int       @id @default(autoincrement())
  firstName String
  lastName  String
  userId    Int       @unique
  birthDate DateTime?
  user      User      @relation(fields: [userId], references: [id])
}

model Study {
  id                            Int      @id @default(autoincrement())
  userId                        Int
  studyName                     String
  studyDate                     DateTime
  socialInsurance               String?
  pdfUrl                        String?
  statusId                      Int
  createdAt                     DateTime @default(now())
  biochemistId                  Int?
  User_Study_biochemistIdToUser User?    @relation("Study_biochemistIdToUser", fields: [biochemistId], references: [id])
  status                        Status   @relation(fields: [statusId], references: [id])
  user                          User     @relation(fields: [userId], references: [id])
}

model Status {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  studies Study[]
}
