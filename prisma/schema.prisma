datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int       @id @default(autoincrement())
  dni       String    @unique
  roleId    Int
  createdAt DateTime  @default(now())

  role      Role      @relation(fields: [roleId], references: [id])
  profile   Profile?
  studies   Study[]
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique

  users User[]
}

model Profile {
  id        Int       @id @default(autoincrement())
  firstName String
  lastName  String
  birthDate DateTime? // mejor que "age"
  userId    Int       @unique

  user User @relation(fields: [userId], references: [id])
}

model Study {
  id                 Int       @id @default(autoincrement())
  userId             Int
  studyName          String
  studyDate          DateTime
  socialInsurance    String?
  assignedBiochemist String?
  pdfUrl             String?
  statusId           Int
  createdAt          DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id])
  status Status @relation(fields: [statusId], references: [id])
}

model Status {
  id     Int     @id @default(autoincrement())
  name   String  @unique

  studies Study[]
}
