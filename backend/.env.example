# =========================
# Server
# =========================
PORT=3000
ALLOWED_ORIGINS="http://localhost:3001"

# =========================
# Database (PostgreSQL)
# =========================
DATABASE_URL=""
DIRECT_URL=""

# =========================
# JWT
# =========================
JWT_SECRET=""
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET=""
JWT_REFRESH_EXPIRES_IN="7d"

# =========================
# Security
# =========================
BCRYPT_SALT_ROUNDS="12"
PLATFORM_BOOTSTRAP_ENABLED=""
ALLOW_PLATFORM_BOOTSTRAP_OVERRIDE=""
BIOCHEMIST_SELF_REGISTER_ENABLED=""

# Rate Limiting por perfil (dejar vacío para usar defaults de producción)
# Login: 10 intentos cada 15 min por IP (skipSuccessfulRequests=true)
RATE_LIMIT_LOGIN_WINDOW_MS=""
RATE_LIMIT_LOGIN_MAX=""
# Recuperación de contraseña: 5 solicitudes cada 60 min por IP
RATE_LIMIT_RECOVERY_WINDOW_MS=""
RATE_LIMIT_RECOVERY_MAX=""
# Reset de contraseña: 5 intentos cada 60 min por IP
RATE_LIMIT_RESET_WINDOW_MS=""
RATE_LIMIT_RESET_MAX=""
# Registro público: 10 registros cada 60 min por IP
RATE_LIMIT_REGISTER_WINDOW_MS=""
RATE_LIMIT_REGISTER_MAX=""
# Acciones admin (bootstrap, cambio de rol, operaciones de plataforma mutantes): 30 cada 15 min
RATE_LIMIT_ADMIN_WINDOW_MS=""
RATE_LIMIT_ADMIN_MAX=""

# Alertas runtime de observabilidad (dejar vacío para usar defaults)
OBS_ALERT_MIN_REQUESTS=""
OBS_ALERT_5XX_RATE_PERCENT=""
OBS_ALERT_4XX_RATE_PERCENT=""
OBS_ALERT_429_COUNT=""
OBS_ALERT_AVG_LATENCY_MS=""
OBS_ALERT_MAX_LATENCY_MS=""

# =========================
# Email Service
# =========================
EMAIL_USER=""
EMAIL_PASSWORD=""
EMAIL_FROM="LabManager <tu-correo@gmail.com>"
EMAIL_SERVICE="gmail"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_TIMEOUT_MS="20000"

# =========================
# Password Recovery
# =========================
PASSWORD_RECOVERY_URL_BASE="http://localhost:3001"
APP_FRONTEND_URL="http://localhost:3001"
ALLOW_RECOVERY_DEBUG_LINK="false"
