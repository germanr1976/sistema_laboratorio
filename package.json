{
  "name": "laboratorioo-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "test:authz:backend": "npm run test:authz -w backend",
    "test:backend": "npm run test -w backend",
    "test:frontend": "npm run test -w frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "ci": "npm run test",
    "smoke:api": "node scripts/smoke-api.mjs",
    "perf:baseline": "node scripts/perf-baseline.mjs",
    "rollback:drill": "node scripts/rollback-drill.mjs",
    "incident:drill": "node scripts/incident-drill.mjs",
    "final:readiness": "node scripts/final-readiness.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}